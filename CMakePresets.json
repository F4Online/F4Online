{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "msvc-x64",
      "displayName": "MSVC x64 (Ninja, Release)",
      "description": "Run from an x64 Native Tools / VS Developer prompt so cl + ninja are on PATH.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "msvc-x64-debug",
      "inherits": "msvc-x64",
      "displayName": "MSVC x64 (Ninja, Debug)",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    { "name": "msvc-x64", "configurePreset": "msvc-x64" },
    { "name": "msvc-x64-debug", "configurePreset": "msvc-x64-debug" }
  ]
}
